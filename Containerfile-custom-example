# Start from the official Fedora 44 Kinoite OCI image
FROM quay.io/fedora/fedora-kinoite:44

# Since we're using bootc, we use standard dnf commands

# External repos go here
RUN dnf -y install \
    https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm \
    https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm && \
    dnf -y clean all

# Removals and swaps
RUN dnf -y remove \
    krfb \
    kjournald \
    kdebugsettings \
    kde-partitionmanager \
    kde-connect \
    kcharselect \
    kfind && \
    dnf -y swap toolbox distrobox --allowerasing && \
    dnf -y clean all

# Multimedia, codecs, drivers, you can add rocm if ever need
RUN dnf -y swap ffmpeg-free ffmpeg --allowerasing && \
    dnf -y install --setopt="install_weak_deps=False" --exclude=PackageKit-gstreamer-plugin @multimedia && \
    dnf -y install \
    mesa-va-drivers-freeworld \
    pipewire-codec-aptx \
    mozilla-openh264 && \
    dnf -y clean all

# Add-ons, weakdeps used where possible except avoid breaking usability
RUN dnf -y install \
    virt-manager libayatana-appindicator-gtk3 \
    gparted \
    btrfs-assistant && \
    dnf install -y --setopt="install_weak_deps=False" \
    podman-compose podman-docker \
    k3b cdrskin \
    btop \
    tailscale \
    trash-cli && \
    dnf -y clean all

# Fonts and setup for custom copy
RUN dnf -y install \
    cjkuni-ukai-fonts \
    cjkuni-uming-fonts \
    jetbrains-mono-fonts \
    impallari-raleway-fonts && \
    dnf -y clean all && \
    mkdir -p /usr/share/fonts/jigmo-fonts

# Copy custom font
COPY ./Jigmo/*.ttf /usr/share/fonts/jigmo-fonts/

# Font setup, service setup, base-system default /etc changes
RUN fc-cache -f && \
    systemctl enable tailscaled.service && \
    systemctl mask sshd.socket sshd.service && \
    touch /etc/containers/nodocker && \
    echo "XMODIFIERS=@im=fcitx" >> /etc/environment && \
    echo "export XMODIFIERS=@im=fcitx" > /etc/profile.d/fcitx.sh

# Important: Label the image as bootc-compatible
LABEL containers.bootc=1
